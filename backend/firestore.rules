rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helper Functions --------
    
    // Check if the authenticated user has the 'owner' role in their profile
    function isOwner() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    // Check if the user is accessing their own data
    function isSelf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // -------- Users Collection --------
    match /users/{userId} {
      // READ: Allow if user is looking at own profile OR is an Owner (for Dashboard List)
      allow read, list: if isSelf(userId) || isOwner();
      
      // CREATE: Allow new users to sign up
      allow create: if isSelf(userId);

      // UPDATE: Allow users to edit profile (Name, Address) but NOT 'role'
      allow update: if isSelf(userId)
                    && !request.resource.data.diff(resource.data).changedKeys().hasAny(['role']);
      
      // DELETE: Not allowed
      allow delete: if false;

      // ---- Nested Notifications ----
      match /notifications/{notificationId} {
        allow read, list, write: if isSelf(userId);
      }

      // ---- Nested Cart ----
      match /cart/{itemId} {
        allow read, list, write: if isSelf(userId);
      }

      // ---- Nested Advisory Reads ----
      match /advisory_reads/{readId} {
        allow read, list, write: if isSelf(userId);
      }
    }

    // -------- Approved Owners (Security Gate) --------
    match /approved_owners/{phone} {
      // Public read for login check, No write for anyone (Console/Admin only)
      allow read: if true; 
      allow write: if false;
    }

    // -------- Master Data (Public Read, Owner Write) --------
    
    // Categories
    match /categories/{id} {
      allow read, list: if true;
      allow write: if isOwner();
    }

    // Products (Root Collection)
    match /products/{id} {
      allow read, list: if true;
      // Allow write for owners OR during order transactions (stock updates)
      allow write: if isOwner();
      // Allow stock updates during authenticated transactions
      allow update: if request.auth != null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']);
    }

    // Banners
    match /banners/{id} {
      allow read, list: if true;
      allow write: if isOwner();
    }

    // Advisories
    match /advisories/{id} {
      allow read, list: if true;
      allow write: if isOwner();
    }

    // -------- Transactional Data --------

    // Orders
    match /orders/{id} {
      // Create: Anyone logged in (Farmer)
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;

      // Read/List: The Farmer who made it OR the Owner
      allow read, list: if request.auth != null 
                        && (resource.data.userId == request.auth.uid || isOwner());
      
      // Update: Owner (Status changes) or Farmer (Cancel)
      allow update: if request.auth != null 
                    && (resource.data.userId == request.auth.uid || isOwner());
      
      // Delete: Not allowed
      allow delete: if false;
    }

    // Credit Ledger (For Farmers/Owner)
    match /creditLedger/{id} {
       // Read/List: Self or Owner
       allow read, list: if request.auth != null 
                         && (resource.data.userId == request.auth.uid || isOwner());
       
       // Write: Owner only (Adding credit/payments)
       allow write: if isOwner();
    }
    
    // Crops (Farmer Data)
    match /crops/{id} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Advisory Messages (Voice/Text from Owner)
    match /advisory_messages/{id} {
      allow read, list: if request.auth != null;
      allow write: if isOwner();
    }

    // -------- Default Deny --------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
